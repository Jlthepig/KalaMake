#version 1.0

#global
    binaryname: test_sha
    binarytype: shared
    buildtype: release
    standard: c11
    sources: "src/lib"
    defines: LIB_EXPORT
    customflags: export-vscode-sln, export-compile-commands

#profile test-sha-release-cl
    compiler: cl
    buildpath: "build/sha-release-cl"

#profile test-sha-release-clang-cl
    compiler: clang-cl
    buildpath: "build/sha-release-clang-cl"

#profile test-sha-release-clang
    compiler: clang
    buildpath: "build/sha-release-clang"

#profile test-sha-release-gcc
    compiler: gcc
    buildpath: "build/sha-release-gcc"

#profile test-sha-release-zig
    compiler: zig
    buildpath: "build/sha-release-zig"
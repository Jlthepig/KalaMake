#version 1.0

#global
binarytype: static
compiler: zig
sources: "src_log_static"

#profile zig-release
binaryname: static-test
buildtype: release
buildpath: "build/static_release"

#profile zig-minsizerel
binaryname: static-test
buildtype: minsizerel
buildpath: "build/static_minsizerel"

#profile zig-debug
binaryname: static-testd
buildtype: debug
buildpath: "build/static_debug"

#profile zig-reldebug
binaryname: static-test
buildtype: reldebug
buildpath: "build/static_reldebug"

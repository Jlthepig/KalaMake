#version 1.0

#references
name-shared: test_sha
dir-win-shared: build\sha-
dir-lin-shared: build/sha-
name-static: test_sta
dir-win-static: build\sta-
dir-lin-static: build/sta-

#global
binaryname: test_exe
binarytype: executable
compiler: zig
customflags: export-vscode-sln

//---------------------------
// EXECUTABLE WITH SHARED LIB
//---------------------------

#profile test-exe-sha-release
buildtype: release
buildpath: "build/exe-sha-release"
sources: "src/exe"

//windows version
//links: "${dir-win-shared}release/${name-shared}.lib"
//linux version
//links: "${dir-lin-shared}release/lib${name-shared}.so"

//windows version
//postbuildaction: copy /Y ${dir-win-shared}release\${name-shared}.dll build\exe-sha-release\${name-shared}.dll
//linux version
//postbuildaction: cp -f ${dir-lin-shared}release/lib${name-shared}.so build/exe-sha-release/lib${name-shared}.so

//---------------------------
// EXECUTABLE WITH STATIC LIB
//---------------------------

#profile test-exe-sta-release
buildtype: release
buildpath: "build/exe-sta-release"
sources: "src/exe"

//windows version
//links: ws2_32, mswsock, kernel32, "${dir-win-static}release\${name-static}.lib"
//linux version
//links: "${dir-lin-static}release/lib${name-static}.so"
#version 1.0

#global
binarytype: shared
compiler: zig
sources: "src_log_shared"

#profile zig-release
binaryname: shared-test
buildtype: release
buildpath: "build/shared_release"

#profile zig-minsizerel
binaryname: shared-test
buildtype: minsizerel
buildpath: "build/shared_minsizerel"

#profile zig-debug
binaryname: shared-testd
buildtype: debug
buildpath: "build/shared_debug"

#profile zig-reldebug
binaryname: shared-test
buildtype: reldebug
buildpath: "build/shared_reldebug"

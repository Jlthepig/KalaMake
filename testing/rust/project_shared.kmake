#version 1.0

#global
compiler: rust
standard: rust24
sources: "src/lib"

//---------------------------
// SHARED LIB
//---------------------------

#profile test-sha-release
binaryname: test_sha
binarytype: shared
buildtype: release
buildpath: "build/sha-release"

#profile test-sha-debug
binaryname: test_shad
binarytype: shared
buildtype: debug
buildpath: "build/sha-debug"

#profile test-sha-reldebug
binaryname: test_sha
binarytype: shared
buildtype: reldebug
buildpath: "build/sha-reldebug"

#profile test-sha-minsizerel
binaryname: test_sha
binarytype: shared
buildtype: minsizerel
buildpath: "build/sha-minsizerel"

#version 1.0

#global
binaryname: test_exe
binarytype: executable
buildtype: release
compiler: rust
sources: "src/basic"
compileflags: -C prefer-dynamic

#profile 2015
standard: rust15
buildpath: "build/exe-basic-2015"

#profile 2024
standard: rust24
buildpath: "build/exe-basic-2024"

#profile linux-gnu
standard: rust24
buildpath: "build/exe-basic-linux-gnu"
targettype: linux-gnu

#profile linux-musl
standard: rust24
buildpath: "build/exe-basic-linux-musl"
targettype: linux-musl

#profile windows-gnu
standard: rust24
buildpath: "build/exe-basic-windows-gnu"
targettype: windows-gnu
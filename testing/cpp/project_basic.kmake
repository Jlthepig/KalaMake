#version 1.0

#global
binaryname: test_exe
binarytype: executable
buildtype: release
compiler: clang++
standard: c++20
sources: "src/exe"
headers: "include"
customflags: export-vscode-sln, export-compile-commands

#profile cpp14
standard: c++14
buildpath: "build/exe-basic-14"

#profile cpp26
standard: c++26
buildpath: "build/exe-basic-26"

#profile linux-gnu
buildpath: "build/exe-basic-linux-gnu"
targettype: linux-gnu

#profile linux-musl
buildpath: "build/exe-basic-linux-musl"
targettype: linux-musl

#profile windows-gnu
buildpath: "build/exe-basic-windows-gnu"
targettype: windows-gnu
